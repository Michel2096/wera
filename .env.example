# ==========================================================
# Configuración de entorno - Health Monitor API
# Copia este archivo como ".env" y completa tus valores reales
# ==========================================================

# --- Entorno de ejecución ---
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-this-super-secret-key-in-production

# --- Servidor ---
# HOST=0.0.0.0 permite que otros dispositivos en la misma red WiFi
# (teléfonos, relojes inteligentes, Expo Go) accedan a la API
HOST=0.0.0.0
PORT=5000

# --- MongoDB Atlas ---
# Ejemplo: mongodb+srv://usuario:password@cluster0.xxxxx.mongodb.net
MONGO_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=health_monitor_db

# --- Sesiones (Flask-Session con MongoDB) ---
SESSION_TYPE=mongodb
SESSION_MONGO_COLLECTION=sessions
SESSION_COOKIE_NAME=health_monitor_session
SESSION_PERMANENT=False
SESSION_LIFETIME_HOURS=12
# En producción con HTTPS, cambia esto a True
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_SAMESITE=Lax

# --- CORS ---
# Lista separada por comas. Usa "*" solo en desarrollo local.
CORS_ORIGINS=*

# --- Simulador de datos biométricos ---
SIMULATION_INTERVAL_SECONDS=3

# --- QR de vinculación de dispositivos ---
QR_TOKEN_EXPIRATION_SECONDS=120

# --- Bcrypt ---
BCRYPT_ROUNDS=12

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
